{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../lib/**/*.ts"],
  "exclude": ["dist", "../node_modules", "../src-tauri/target"]
}
